# Backend Environment Variables
# ================================

# Server Configuration
NODE_ENV=development
PORT=5000
HOST=localhost

# MongoDB Database
MONGODB_URL=mongodb://localhost:27017/study-assistant

# LM Studio Configuration
# Note: You need 2 models running in LM Studio
# 1. Text embedding model (for RAG/vector search)
# 2. Chat/Code model (for responses)

# Chat Model Configuration (Qwen2.5 Coder)
LM_STUDIO_CHAT_URL=http://localhost:1234/v1
LM_STUDIO_CHAT_MODEL=qwen2.5-coder

# Embedding Model Configuration (Text Embedding)
LM_STUDIO_EMBEDDING_URL=http://localhost:1235/v1
LM_STUDIO_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRATION=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Email Configuration (Gmail SMTP)
EMAIL_USER=asadkhurshid20012001@gmail.com
EMAIL_PASSWORD=your-app-password-here
EMAIL_FROM_NAME=AI Study Assistant
EMAIL_FROM_EMAIL=asadkhurshid20012001@gmail.com

# SMTP Configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Admin Email (for admin notifications)
ADMIN_EMAIL=asadkhurshid20012001@gmail.com

# Socket.io Configuration
SOCKET_ORIGINS=http://localhost:3000,http://localhost:3001

# Session Configuration
SESSION_SECRET=your-session-secret-change-this
INACTIVITY_TIMEOUT=15

# API Configuration
API_RATE_LIMIT=100
API_RATE_WINDOW=15

# Logging
LOG_LEVEL=debug

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

# Vector Database
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=documents
